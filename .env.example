# Required environment variables — copy to .env.local and fill in values

# For Railway deploy: use the internal URL (postgres.railway.internal) — set in Railway dashboard
# For local dev / running seed scripts: use the PUBLIC proxy URL from Railway dashboard
# (Railway Variables tab shows both DATABASE_URL and DATABASE_PUBLIC_URL)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

ANTHROPIC_API_KEY="sk-ant-..."
